<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find bw_description)/xacro/transmission.xacro"/>

  <!-- 宏1：核心关节（hip/thigh/calf）及相关配置 -->
  <xacro:macro name="leg_core" params="name mirror mirror_dae front_hind front_hind_dae">
    <!-- 髋关节定义 -->
    <joint name="${name}_hip_joint" type="revolute">
      <xacro:if value="${(mirror_dae == False) and (front_hind_dae == True)}">
        <origin rpy="0 0 0" xyz="${hip_offset_x} ${-hip_offset_y} ${hip_offset_z}"/>
      </xacro:if>
      <xacro:if value="${(mirror_dae == True) and (front_hind_dae == True)}">
        <origin rpy="0 0 0" xyz="${hip_offset_x} ${hip_offset_y} ${hip_offset_z}"/>
      </xacro:if>
      <xacro:if value="${(mirror_dae == False) and (front_hind_dae == False)}">
        <origin rpy="0 0 0" xyz="${-hip_offset_x} ${-hip_offset_y} ${hip_offset_z}"/>
      </xacro:if>
      <xacro:if value="${(mirror_dae == True) and (front_hind_dae == False)}">
        <origin rpy="0 0 0" xyz="${-hip_offset_x} ${hip_offset_y} ${hip_offset_z}"/>
      </xacro:if>
      <parent link="trunk"/>
      <child link="${name}_hip"/>
      <axis xyz="1 0 0"/>
      <dynamics damping="${damping}" friction="${friction}"/>
      <xacro:if value="${(mirror_dae == True)}">
        <limit effort="${hip_torque_max}" velocity="${hip_velocity_max}" lower="${hip_position_min}"
               upper="${hip_position_max}"/>
      </xacro:if>
      <xacro:if value="${(mirror_dae == False)}">
        <limit effort="${hip_torque_max}" velocity="${hip_velocity_max}" lower="${-hip_position_max}"
               upper="${-hip_position_min}"/>
      </xacro:if>
    </joint>

    <link name="${name}_hip">
      <visual>
        <xacro:if value="${(mirror_dae == True) and (front_hind_dae == True)}">
          <origin rpy="0 0 0" xyz="0 0 0"/>
        </xacro:if>
        <xacro:if value="${(mirror_dae == False) and (front_hind_dae == True)}">
          <origin rpy="${PI} 0 0" xyz="0 0 0"/>
        </xacro:if>
        <xacro:if value="${(mirror_dae == True) and (front_hind_dae == False)}">
          <origin rpy="0 ${PI} 0" xyz="0 0 0"/>
        </xacro:if>
        <xacro:if value="${(mirror_dae == False) and (front_hind_dae == False)}">
          <origin rpy="${PI} ${PI} 0" xyz="0 0 0"/>
        </xacro:if>
        <geometry>
          <mesh filename="file://$(find bw_description)/meshes/hip.stl" scale="1 1 1"/>
        </geometry>
      </visual>
      <collision>
        <origin rpy="${PI/2.0} 0 0" xyz="0 ${thigh_collision_offset_y*mirror} 0"/>
        <geometry>
          <cylinder length="${hip_length}" radius="${hip_radius}"/>
        </geometry>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="${hip_com_x*front_hind} ${hip_com_y*mirror} ${hip_com_z}"/>
        <mass value="${hip_mass}"/>
        <inertia
            ixx="${hip_ixx}" ixy="${hip_ixy*mirror*front_hind}" ixz="${hip_ixz*front_hind}"
            iyy="${hip_iyy}" iyz="${hip_iyz*mirror}"
            izz="${hip_izz}"/>
      </inertial>
    </link>

    <!-- 大腿关节定义 -->
    <joint name="${name}_thigh_joint" type="revolute">
      <origin rpy="0 0 0" xyz="0 ${thigh_offset_y*mirror} 0"/>
      <parent link="${name}_hip"/>
      <child link="${name}_thigh"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="${damping}" friction="${friction}"/>
      <xacro:if value="${front_hind == 1}">  <!-- 前腿 -->
        <limit effort="${thigh_torque_max}" velocity="${thigh_velocity_max}" lower="${thigh_position_min_qian}" upper="${thigh_position_max_qian}"/>
      </xacro:if>
      <xacro:if value="${front_hind == -1}"> <!-- 后腿 -->
        <limit effort="${thigh_torque_max}" velocity="${thigh_velocity_max}" lower="${thigh_position_min_hou}" upper="${thigh_position_max_hou}"/>
      </xacro:if>
    </joint>

    <link name="${name}_thigh">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <xacro:if value="${mirror_dae == True}">
            <mesh filename="file://$(find bw_description)/meshes/thigh.stl" scale="1 1 1"/>
          </xacro:if>
          <xacro:if value="${mirror_dae == False}">
            <mesh filename="file://$(find bw_description)/meshes/thigh_mirror.stl" scale="1 1 1"/>
          </xacro:if>
        </geometry>
      </visual>
      <collision>
        <origin rpy="0 ${PI/2.0} 0" xyz="0 ${-0.005*mirror} ${-thigh_length/2.0}"/>
        <geometry>
          <box size="${thigh_length} ${thigh_width} ${thigh_height}"/>
        </geometry>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="${thigh_com_x*front_hind} ${thigh_com_y*mirror} ${thigh_com_z}"/>
        <mass value="${thigh_mass}"/>
        <inertia
            ixx="${thigh_ixx}" ixy="${thigh_ixy*mirror*front_hind}" ixz="${thigh_ixz*front_hind}"
            iyy="${thigh_iyy}" iyz="${thigh_iyz*mirror}"
            izz="${thigh_izz}"/>
      </inertial>
    </link>

    <!-- 小腿关节定义 -->
    <joint name="${name}_calf_joint" type="revolute">
      <origin rpy="0 0 0" xyz="0 ${calf_offset_y*mirror} ${calf_offset_z}"/>
      <parent link="${name}_thigh"/>
      <child link="${name}_calf"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="${damping}" friction="${friction}"/>
      <limit effort="${calf_torque_max}" velocity="${calf_velocity_max}" lower="${calf_position_min}"
             upper="${calf_position_max}"/>
    </joint>

    <link name="${name}_calf">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <xacro:if value="${mirror_dae == True}">
            <mesh filename="file://$(find bw_description)/meshes/calf.stl" scale="1 1 1"/>
          </xacro:if>
          <xacro:if value="${mirror_dae == False}">
            <mesh filename="file://$(find bw_description)/meshes/calf_mirror.stl" scale="1 1 1"/>
          </xacro:if>
        </geometry>
      </visual>
      <collision>
        <origin rpy="0 ${PI/2.0} 0" xyz="0 0 ${-calf_length/2.0+0.025}"/>
        <geometry>
          <box size="${calf_length} ${calf_width} ${calf_height}"/>
        </geometry>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="${calf_com_x*front_hind} ${calf_com_y*mirror} ${calf_com_z}"/>
        <mass value="${calf_mass}"/>
        <inertia
            ixx="${calf_ixx}" ixy="${calf_ixy*mirror*front_hind}" ixz="${calf_ixz*front_hind}"
            iyy="${calf_iyy}" iyz="${calf_iyz*mirror}"
            izz="${calf_izz}"/>
      </inertial>
    </link>

    <!-- 核心关节的传动配置 -->
    <xacro:leg_core_transmission name="${name}"/>
  </xacro:macro>

  <!-- 宏2：足部关节（foot）及相关配置 -->
  <xacro:macro name="leg_foot" params="name mirror mirror_dae front_hind front_hind_dae">
    <!-- 足部关节定义 - 已修改为continuous类型 -->
    <joint name="${name}_foot_joint" type="continuous">
      <origin xyz="0 ${foot_offset_y*mirror} ${foot_offset_z}" rpy="0 0 0"/>
      <parent link="${name}_calf"/>  
      <child link="${name}_foot"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="${damping}" friction="${friction}"/>
      <limit effort="${foot_torque_max}" velocity="${foot_velocity_max}"/>
    </joint>
  
   <!-- 0.0515-->
    <link name="${name}_foot">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <xacro:if value="${mirror_dae == True}">
            <mesh filename="file://$(find bw_description)/meshes/wheel.stl"/>
          </xacro:if>
          <xacro:if value="${mirror_dae == False}">
            <mesh filename="file://$(find bw_description)/meshes/wheel_mirror.stl"/>
          </xacro:if>
        </geometry>
        <material name="">
          <color rgba="1 1 1 1"/>
        </material>
      </visual>
      <collision>
        <origin rpy="${PI/2.0} 0 0" xyz="0 ${foot_collision_offset_y*mirror} 0"/>
        <geometry>
          <cylinder length="${foot_height}" radius="${foot_radius}"/>
        </geometry>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="${foot_com_x*front_hind} ${foot_com_y*mirror} ${foot_com_z}"/>
        <mass value="${foot_mass}"/>
        <inertia
            ixx="${foot_ixx}" ixy="${foot_ixy*mirror*front_hind}" ixz="${foot_ixz*front_hind}"
            iyy="${foot_iyy}" iyz="${foot_iyz*mirror}"
            izz="${foot_izz}"/>
      </inertial>
    </link>

    <!-- 足部关节的传动配置 -->
    <xacro:leg_foot_transmission name="${name}"/>
  </xacro:macro>

</robot>
