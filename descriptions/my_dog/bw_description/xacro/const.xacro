	<!-- foot -->
	<!-- 足部参数 -->
	<xacro:property name="foot_mass" value="0.6959"/> <!-- 足部质量 -->
	<xacro:property name="foot_com_x" value="3.61016876218034E-05"/> <!-- 小腿质心在X轴的位置： -->
	<xacro:property name="foot_com_y" value="-0.0115832620181727"/> <!-- 小腿质心在Y轴的位置： -->
	<xacro:property name="foot_com_z" value="-8.02701045317655E-05"/> <!-- 小腿质心在Z轴的位置：（长度缩放后） -->
	<xacro:property name="foot_ixx" value="0.00216437"/> <!-- 小腿绕X轴的转动惯量：  -->
	<xacro:property name="foot_ixy" value="0.00000023"/> <!-- 小腿绕X-Y轴的惯性积：  -->
	<xacro:property name="foot_ixz" value="0.00000129"/> <!-- 小腿绕X-Z轴的惯性积： -->
	<xacro:property name="foot_iyy" value="0.00415580"/> <!-- 小腿绕Y轴的转动惯量： -->
	<xacro:property name="foot_iyz" value="-0.00000010"/> <!-- 小腿绕Y-Z轴的惯性积： -->
	<xacro:property name="foot_izz" value="0.00216126"/> <!-- 小腿绕Z轴的转动惯量： -->

	
	

	
	
</robot>
